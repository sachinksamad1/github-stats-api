{
  "name": "github-stats-api",
  "version": "1.0.0",
  "description": "Dynamic SVG GitHub stats API — self-hosted, customizable, TypeScript",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/server.js",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "keywords": [
    "github",
    "stats",
    "svg",
    "api",
    "typescript"
  ],
  "author": "Sachin K Samad",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sachinksamad1/github-stats-api.git"
  },
  "bugs": {
    "url": "https://github.com/sachinksamad1/github-stats-api/issues"
  },
  "homepage": "https://github.com/sachinksamad1/github-stats-api#readme",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.5"
  }
}
